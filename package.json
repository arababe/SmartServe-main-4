{
  "name": "smartserve",
  "version": "1.0.0",
  "description": "Dynamic MERN Stack Boilerplate",
  "scripts": {
    "setup": "node setup.js",
    "install:all": "cd server && npm install && cd ../client && npm install",
    "dev": "concurrently \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "start": "cd server && npm start",
    "build": "cd client && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "nodemailer": "^8.0.7",
    "react-qr-code": "^2.0.21"
  }
}
